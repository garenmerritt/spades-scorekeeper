generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  name      String?
  createdAt DateTime @default(now())
  games     Game[]
}

model Game {
  id           String   @id @default(cuid())
  userId       String
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  team1Name    String
  team2Name    String
  team1Score   Int
  team2Score   Int
  winCondition Int
  bagsOn       Boolean
  winner       String   // "0", "1", or "tie"
  rounds       Json     // Full round-by-round breakdown
  totalRounds  Int
  createdAt    DateTime @default(now())

  @@index([userId, createdAt])
}
